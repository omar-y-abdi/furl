{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash|WebFetch|WebSearch|Task",
        "hooks": [
          {
            "type": "command",
            "command": "sh -lc 'uv run --no-project --with \"furl-ctx[mcp]\" python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/compress_tool_output.py\" || true'",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
